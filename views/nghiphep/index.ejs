<div class="page-header">
    <div class="header-titles">
        <h1 class="page-title">Quản Lý Nghỉ Phép</h1>
        <p class="page-subtitle">Nộp đơn và phê duyệt yêu cầu nghỉ của nhân sự</p>
    </div>
    <div class="header-actions">
        <button class="btn btn-primary" onclick="document.getElementById('leaveModal').style.display='flex'">
            <i class="fa-solid fa-paper-plane"></i> Gửi Đơn Nghỉ Phép
        </button>
    </div>
</div>

<div class="card table-card">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center;">
        <h3><i class="fa-solid fa-list-check text-primary"></i> Danh Sách Yêu Cầu</h3>
        <button type="button" class="btn btn-outline btn-sm" id="refreshLeaveRequestsBtn">
            <i class="fa-solid fa-rotate-right"></i> Làm Mới
        </button>
    </div>
    <div class="card-body" style="padding: 0;">
        <table class="data-table">
            <thead>
                <tr>
                    <% if (user && user.role === 'Admin') { %>
                        <th>Nhân Viên</th>
                    <% } %>
                    <th>Loại Nghỉ</th>
                    <th>Thời Gian</th>
                    <th>Lý Do</th>
                    <th>Trạng Thái</th>
                    <th class="actions-col">Thao Tác</th>
                </tr>
            </thead>
            <tbody id="leaveRequestsTableBody" data-is-admin="<%= user && user.role === 'Admin' ? 'true' : 'false' %>">
                <% if (requests.length > 0) { %>
                    <% requests.forEach(item => { %>
                        <tr>
                            <% if (user && user.role === 'Admin') { %>
                                <td><strong><%= item.NhanVien ? item.NhanVien.HoVaTen : 'N/A' %></strong></td>
                            <% } %>
                            <td><%= item.LoaiNghi %></td>
                            <td>
                                <div style="font-size: 0.85rem;">
                                    Từ: <%= moment(item.TuNgay).format('DD/MM/YYYY') %><br>
                                    Đến: <%= moment(item.DenNgay).format('DD/MM/YYYY') %>
                                </div>
                            </td>
                            <td><span title="<%= item.LyDo %>" style="cursor: help;"><%= item.LyDo.length > 30 ? item.LyDo.substring(0, 30) + '...' : item.LyDo %></span></td>
                            <td>
                                <% if (item.TrangThai === 'Chờ duyệt') { %>
                                    <span class="status status-warning">Chờ duyệt</span>
                                <% } else if (item.TrangThai === 'Đã duyệt') { %>
                                    <span class="status status-success">Đã duyệt</span>
                                <% } else { %>
                                    <span class="status status-danger">Từ chối</span>
                                <% } %>
                            </td>
                            <td class="actions-col">
                                <% if (user && user.role === 'Admin' && item.TrangThai === 'Chờ duyệt') { %>
                                    <a href="/nghiphep/duyet/<%= item._id %>" class="action-btn btn-view" title="Duyệt" style="color: var(--success);"><i class="fa-solid fa-check-circle"></i></a>
                                    <a href="/nghiphep/tu-choi/<%= item._id %>" class="action-btn btn-delete" title="Từ chối"><i class="fa-solid fa-times-circle"></i></a>
                                <% } else { %>
                                    <span class="text-muted" style="font-size: 0.8rem;">Không có thao tác</span>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="6" class="text-center" style="padding: 3rem;">Chưa có đơn nghỉ phép nào được tạo.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Gửi Đơn Nghỉ Phép -->
<div id="leaveModal" class="modal">
    <div class="modal-content card" style="max-width: 600px;">
        <div class="modal-header">
            <h3>Gửi Đơn Xin Nghỉ Phép</h3>
            <span class="close" onclick="document.getElementById('leaveModal').style.display='none'">&times;</span>
        </div>
        <div class="modal-body">
            <form action="/nghiphep/gui-don" method="POST" class="modern-form">
                <div class="form-row">
                    <div class="form-group half">
                        <label>Từ Ngày <span class="required">*</span></label>
                        <input type="date" name="TuNgay" class="form-control" required>
                    </div>
                    <div class="form-group half">
                        <label>Đến Ngày <span class="required">*</span></label>
                        <input type="date" name="DenNgay" class="form-control" required>
                    </div>
                </div>
                <div class="form-group mt-3">
                    <label>Loại Nghỉ</label>
                    <select name="LoaiNghi" class="form-control">
                        <option value="Nghỉ có phép">Nghỉ có phép</option>
                        <option value="Nghỉ không phép">Nghỉ không phép</option>
                        <option value="Nghỉ ốm">Nghỉ ốm</option>
                        <option value="Việc riêng">Việc riêng</option>
                    </select>
                </div>
                <div class="form-group mt-3">
                    <label>Lý Do <span class="required">*</span></label>
                    <textarea name="LyDo" class="form-control" rows="4" required placeholder="Nhập lý do xin nghỉ chi tiết..."></textarea>
                </div>
                <div class="form-actions mt-4 text-right">
                    <button type="button" class="btn btn-outline" onclick="document.getElementById('leaveModal').style.display='none'">Hủy</button>
                    <button type="submit" class="btn btn-primary ml-2">Gửi Đơn</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .form-row { display: flex; gap: 1rem; }
    .half { flex: 1; }
</style>
