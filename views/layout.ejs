<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Premium HR</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="layout-wrapper">
        <%- include('navbar') %>

        <main class="main-content">
            <header class="topbar">
                <div class="search-container" style="display: flex; gap: 1rem;">
                    <% if (path && path.startsWith('/phongban')) { %>
                        <%- include('timkiem_phongban') %>
                    <% } else if (path && path.startsWith('/nhanvien')) { %>
                        <%- include('timkiem_nhanvien') %>
                    <% } else { %>
                        <div class="search-bar" style="opacity: 0; pointer-events: none;">
                            <input type="text">
                        </div>
                    <% } %>
                </div>
            </header>

            <div class="content-container">
                <%- message %>
                <%- body %>
            </div>

            <%- include('footer') %>
        </main>
    </div>
    <script src="/js/script.js"></script>
</body>
</html>
