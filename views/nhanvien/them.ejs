<div class="page-header">
    <div class="header-titles">
        <h1 class="page-title">Thêm Nhân Viên</h1>
        <p class="page-subtitle">Nhập thông tin nhân sự mới</p>
    </div>
    <div class="header-actions">
        <a href="/nhanvien" class="btn btn-outline"><i class="fa-solid fa-arrow-left"></i> Quay lại</a>
    </div>
</div>

<div class="card form-card">
    <div class="card-body">
        <form action="/nhanvien/them" method="POST" class="modern-form">
            <div class="form-row">
                <div class="form-group half">
                    <label>Mã Nhân Viên <span class="required">*</span></label>
                    <input type="text" name="MaNV" class="form-control" required placeholder="VD: NV001">
                </div>
                <div class="form-group half">
                    <label>Họ & Tên <span class="required">*</span></label>
                    <input type="text" name="HoVaTen" class="form-control" required placeholder="Nhập họ và tên đầy đủ">
                </div>
            </div>

            <div class="form-row">
                <div class="form-group half">
                    <label>Email <span class="required">*</span></label>
                    <input type="email" name="Email" class="form-control" required placeholder="nam.nguyen@company.com">
                </div>
                <div class="form-group half">
                    <label>Số Điện Thoại <span class="required">*</span></label>
                    <input type="text" name="SoDienThoai" class="form-control" required pattern="[0-9]{10}" title="Số điện thoại phải gồm 10 chữ số" placeholder="0901234567">
                </div>
            </div>

            <div class="form-row">
                <div class="form-group half">
                    <label>Phòng Ban</label>
                    <div class="select-wrapper">
                        <select name="PhongBan" class="form-control">
                            <option value="">-- Chọn phòng ban --</option>
                            <% phongbans.forEach(pb => { %>
                                <option value="<%= pb._id %>"><%= pb.TenPhongBan %></option>
                            <% }) %>
                        </select>
                        <i class="fa-solid fa-chevron-down select-icon"></i>
                    </div>
                </div>
                <div class="form-group half">
                    <label>Chức Vụ <span class="required">*</span></label>
                    <input type="text" name="ChucVu" class="form-control" required placeholder="Nhân viên, Trưởng phòng...">
                </div>
            </div>

            <div class="form-row">
                <div class="form-group half">
                    <label>Mức Lương Trực Tiếp (VNĐ)</label>
                    <input type="number" name="Luong" class="form-control" placeholder="Ví dụ: 15000000">
                </div>
                <div class="form-group half">
                    <label>Mật Khẩu <span class="required">*</span></label>
                    <input type="text" name="MatKhau" class="form-control" required value="123456" placeholder="Mật khẩu đăng nhập">
                </div>
            </div>

            <div class="form-actions mt-4">
                <button type="submit" class="btn btn-primary btn-lg"><i class="fa-solid fa-user-plus"></i> Lưu Nhân Viên</button>
            </div>
        </form>
    </div>
</div>
