<div class="page-header">
    <div class="header-titles">
        <h1 class="page-title">Sửa Nhân Viên</h1>
        <p class="page-subtitle">Cập nhật thông tin: <strong><%= nhanvien.HoVaTen %></strong></p>
    </div>
    <div class="header-actions">
        <a href="/nhanvien" class="btn btn-outline"><i class="fa-solid fa-arrow-left"></i> Quay lại</a>
    </div>
</div>

<div class="card form-card">
    <div class="card-body">
        <form action="/nhanvien/sua/<%= nhanvien._id %>" method="POST" class="modern-form">
            <div class="form-row">
                <div class="form-group half">
                    <label>Mã Nhân Viên <span class="required">*</span></label>
                    <input type="text" name="MaNV" class="form-control" required value="<%= nhanvien.MaNV %>">
                </div>
                <div class="form-group half">
                    <label>Họ & Tên <span class="required">*</span></label>
                    <input type="text" name="HoVaTen" class="form-control" required value="<%= nhanvien.HoVaTen %>">
                </div>
            </div>

            <div class="form-row">
                <div class="form-group half">
                    <label>Email <span class="required">*</span></label>
                    <input type="email" name="Email" class="form-control" required value="<%= nhanvien.Email %>">
                </div>
                <div class="form-group half">
                    <label>Số Điện Thoại <span class="required">*</span></label>
                    <input type="text" name="SoDienThoai" class="form-control" required pattern="[0-9]{10}" title="Số điện thoại phải gồm 10 chữ số" value="<%= nhanvien.SoDienThoai %>">
                </div>
            </div>

            <div class="form-row">
                <div class="form-group half">
                    <label>Phòng Ban</label>
                    <div class="select-wrapper">
                        <select name="PhongBan" class="form-control">
                            <option value="">-- Chọn phòng ban --</option>
                            <% phongbans.forEach(pb => { %>
                                <option value="<%= pb._id %>" <%= nhanvien.PhongBan && nhanvien.PhongBan.toString() === pb._id.toString() ? 'selected' : '' %>>
                                    <%= pb.TenPhongBan %>
                                </option>
                            <% }) %>
                        </select>
                        <i class="fa-solid fa-chevron-down select-icon"></i>
                    </div>
                </div>
                <div class="form-group half">
                    <label>Chức Vụ <span class="required">*</span></label>
                    <input type="text" name="ChucVu" class="form-control" required value="<%= nhanvien.ChucVu %>">
                </div>
            </div>

            <div class="form-row">
                <div class="form-group half">
                    <label>Mức Lương Trực Tiếp (VNĐ)</label>
                    <input type="number" name="Luong" class="form-control" value="<%= nhanvien.Luong %>">
                </div>
                <div class="form-group half">
                    <label>Trạng Thái</label>
                    <div class="select-wrapper">
                        <select name="TrangThai" class="form-control">
                            <option value="Đang làm việc" <%= nhanvien.TrangThai === 'Đang làm việc' ? 'selected' : '' %>>Đang làm việc</option>
                            <option value="Tạm hoãn" <%= nhanvien.TrangThai === 'Tạm hoãn' ? 'selected' : '' %>>Tạm hoãn</option>
                            <option value="Đã nghỉ việc" <%= nhanvien.TrangThai === 'Đã nghỉ việc' ? 'selected' : '' %>>Đã nghỉ việc</option>
                        </select>
                        <i class="fa-solid fa-chevron-down select-icon"></i>
                    </div>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group half">
                    <label>Đổi Mật Khẩu (Để trống nếu không đổi)</label>
                    <input type="text" name="MatKhau" class="form-control" placeholder="Nhập mật khẩu mới...">
                </div>
            </div>

            <div class="form-actions mt-4">
                <button type="submit" class="btn btn-primary btn-lg"><i class="fa-solid fa-floppy-disk"></i> Cập Nhật Nhân Viên</button>
            </div>
        </form>
    </div>
</div>
